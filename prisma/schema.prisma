generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BalanceSnapshot {
  id               String   @id @default(uuid()) @db.Uuid
  address          String
  snapshotDate     DateTime @map("snapshot_date") @db.Date
  scaledBalance    Decimal  @map("scaled_balance") @db.Decimal(78, 0)
  liquidityIndex   Decimal  @map("liquidity_index") @db.Decimal(78, 0)
  underlyingValue  Decimal  @map("underlying_value") @db.Decimal(78, 0)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([address, snapshotDate])
  @@index([address, snapshotDate(sort: Desc)])
  @@map("balance_snapshots")
}
