# Supabase — create a project at https://supabase.com
# ⚠️  Do NOT include /rest/v1/ suffix — the client library adds it automatically
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...          # service_role key (server-side only)

# Wallet to track
NEXT_PUBLIC_WALLET_ADDRESS=0xYourWalletAddressHere

# Ethereum RPC (Alchemy / Infura / public)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Cron security — generate with `openssl rand -hex 32`
CRON_SECRET=your-random-secret-here
